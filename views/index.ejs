<!DOCTYPE html>
<html lang="en">

<head>

  <!-- Page Metadata -->
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <!-- Page Title -->
  <title>Blog</title>

  <!-- External Stylesheet -->
  <link
    rel="stylesheet"
    href="/styles/main.css"
  >

</head>

<body>

  <!-- Main Container -->
  <div class="container">

    <!-- Blog Heading -->
    <h1>My Blog</h1>


    <!-- New Post Navigation -->
    <a
      id="newPostBtn"
      href="/new"
    >
      New Post
    </a>


    <!-- Blog Posts List -->
    <ul id="postsList">

      <% posts.forEach(post => { %>

        <li>

          <!-- Post Title -->
          <h2>
            <%= post.title %>
          </h2>


          <!-- Post Date -->
          <small>
            <%= post.date %>
          </small>


          <!-- Post Content -->
          <p>
            <%= post.content %>
          </p>


          <!-- Post Author -->
          <small>
            By: <%= post.author %>
          </small>


          <!-- Post Actions -->
          <a
            class="edit"
            href="/edit/<%= post.id %>"
          >
            Edit
          </a>

          <a
            class="delete"
            href="/api/posts/delete/<%= post.id %>"
          >
            Delete
          </a>

        </li>

      <% }); %>

    </ul>

  </div>

</body>

</html>